            "command": ".venv\\Scripts\\python manage.py runserver",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Django: Make Migrations",
            "type": "shell",
            "command": ".venv\\Scripts\\python manage.py makemigrations",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Django: Migrate",
            "type": "shell",
            "command": ".venv\\Scripts\\python manage.py migrate",
            "group": "build",
