                "Django: Make Migrations"
            ],
            "problemMatcher": []
        },
        {
            "label": "Django: Import Data",
            "type": "shell",
            "command": ".venv\\Scripts\\python import_data.py",
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "orthoaget: force reinstall",
            "type": "shell",
            "windows": {
                "command": ".venv\\Scripts\\pip install --force-reinstall \"git+https://github.com/clombec/OrthoAParse.git@main#egg=orthoaget\""
            },
            "osx": {
                "command": ".venv/bin/pip install --force-reinstall 'git+https://github.com/clombec/OrthoAParse.git@main#egg=orthoaget'"
            },
            "linux": {
                "command": ".venv/bin/pip install --force-reinstall 'git+https://github.com/clombec/OrthoAParse.git@main#egg=orthoaget'"
            },
            "group": {
                "kind": "build",
                "isDefault": true
